{
  "menu_schema": [
    {
      "id": "system_options",
      "text": "Opties",
      "image": "system.png",
      "action": "open_page",
      "order": 100,
      "screen": [
        {
          "id": "options_back",
          "text": "Terug",
          "image": "back.png",
          "action": "back",
          "order": 10
        },
        {
          "id": "store_settings",
          "text": "Store settings",
          "image": "system.png",
          "action": "store_settings",
          "order": 20
        },
        {
          "id": "force_fullscreen",
          "text": "Force fullscreen",
          "image": "system.png",
          "action": "force_fullscreen",
          "order": 30
        },
        {
          "id": "quit",
          "text": "Sluit deze app",
          "image": "exit.png",
          "action": "exit",
          "order": 40
        },
        {
          "id": "shell_reboot",
          "text": "Reboot machine",
          "image": "shell.png",
          "action": "shell_reboot",
          "dev_only": true,
          "order": 50
        },
        {
          "id": "shell_shutdown",
          "text": "Shutdown machine",
          "image": "shell.png",
          "action": "shell_shutdown",
          "dev_only": true,
          "order": 60
        }
      ]
    },
    {
      "id": "screen_off",
      "text": "Zet scherm uit",
      "image": "screen-off.png",
      "action": "turn_screen_off",
      "order": 200
    },
    {
      "id": "sleep_mode",
      "text": "[sleep_mode_action] Sleep mode",
      "image": "in-bed.png",
      "action": "sleep_mode_toggle",
      "order": 300
    }
  ],
  "button_setting_requirements": {
    "store_settings": []
  },
  "action_specs": {
    "back": {
      "kind": "menu_nav",
      "command": "back"
    },
    "close": {
      "kind": "menu_nav",
      "command": "exit"
    },
    "turn_screen_off": {
      "kind": "custom",
      "name": "turn_screen_off"
    },
    "sleep_mode_toggle": {
      "kind": "mqtt_action",
      "topic_key": "actions_outgoing",
      "action": "sleep_mode_toggle"
    },
    "music_play_pause": {
      "kind": "media",
      "op": "play_pause"
    },
    "music_volume_up": {
      "kind": "media",
      "op": "volume",
      "arg": "up"
    },
    "music_volume_down": {
      "kind": "media",
      "op": "volume",
      "arg": "down"
    },
    "music_next": {
      "kind": "media",
      "op": "skip",
      "arg": "next"
    },
    "music_previous": {
      "kind": "media",
      "op": "skip",
      "arg": "previous"
    },
    "music_show_title": {
      "kind": "custom",
      "name": "music_show_title"
    },
    "show_weather_on_idle": {
      "kind": "setting_toggle",
      "attr": "show_weather_on_idle"
    },
    "media_show_titles": {
      "kind": "setting_toggle",
      "attr": "media_show_titles"
    },
    "media_sanitize_titles": {
      "kind": "setting_toggle",
      "attr": "media_sanitize_titles"
    },
    "media_show_album": {
      "kind": "setting_toggle",
      "attr": "media_show_album"
    },
    "store_settings": {
      "kind": "setting_toggle",
      "attr": "store_settings"
    },
    "force_fullscreen": {
      "kind": "custom",
      "name": "force_fullscreen"
    },
    "shell_reboot": {
      "kind": "shell",
      "op": "reboot"
    },
    "shell_shutdown": {
      "kind": "shell",
      "op": "shutdown"
    },
    "exit": {
      "kind": "app_exit"
    }
  },
  "state_specs": [
    {
      "button_id": "sleep_mode",
      "type": "device_bool",
      "source": "sleep_mode",
      "default": false,
      "action_text": "[sleep_mode_action]",
      "on_text": "Aan",
      "off_text": "Uit"
    },
    {
      "button_id": "store_settings",
      "type": "setting_bool",
      "source": "store_settings",
      "default": true
    }
  ]
}
