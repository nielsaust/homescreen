  "state_specs": [
    {
      "button_id": "cinema",
      "type": "device_not_equals",
      "source": "harmony_state",
      "value": "Off",
      "action_text": "[cinema_action]",
      "on_text": "uit",
      "off_text": "aan"
    },
    {
      "button_id": "cover_kitchen",
      "type": "device_less_than",
      "source": "cover_kitchen",
      "value": 50,
      "default": 0,
      "action_text": "[cover_action]",
      "on_text": "open",
      "off_text": "dicht"
    },
    {
      "button_id": "in_bed_toggle",
      "type": "device_bool",
      "source": "in_bed",
      "default": false,
      "action_text": "[sleep_mode_action]",
      "on_text": "uit",
      "off_text": "aan"
    },
    {
      "button_id": "sleep_mode_toggle_option",
      "type": "device_bool",
      "source": "in_bed",
      "default": false,
      "action_text": "[sleep_mode_action]",
      "on_text": "uit",
      "off_text": "aan"
    },
    {
      "button_id": "trash_warning_toggle",
      "type": "device_bool",
      "source": "trash_warning",
      "default": false,
      "action_text": "[trash_action]",
      "on_text": "uit",
      "off_text": "aan"
    },
    {
      "button_id": "music_play_pause",
      "type": "music_state",
      "state": "playing",
      "action_text": "[music_action]",
      "on_text": "Pauzeer",
      "off_text": "Speel"
    },
    {
      "button_id": "ps_toggle",
      "type": "device_bool",
      "source": "playstation_power",
      "default": false,
      "action_text": "[ps_action]",
      "on_text": "uit",
      "off_text": "aan",
      "available_source": "playstation_available",
      "available_default": true
    },
    {
      "button_id": "light_woonkamer",
      "type": "light",
      "source": "light_woonkamer",
      "action_text": "[woonkamer_licht_action]",
      "on_text": "({brightness}%) uit",
