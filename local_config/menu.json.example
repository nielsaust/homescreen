{
  "menu_schema": [
    {
      "id": "system_options",
      "text": "Opties",
      "image": "system.png",
      "action": "open_page",
      "order": 100,
      "screen": [
        {
          "id": "options_back",
          "text": "Terug",
          "image": "back.png",
          "action": "back",
          "order": 10,
          "action_spec": {
            "kind": "menu_nav",
            "command": "back"
          }
        },
        {
          "id": "store_settings",
          "text": "Store settings",
          "image": "system.png",
          "action": "store_settings",
          "order": 20,
          "setting_requirements": [],
          "action_spec": {
            "kind": "setting_toggle",
            "attr": "store_settings"
          },
          "state_spec": {
            "type": "setting_bool",
            "source": "store_settings",
            "default": true
          }
        },
        {
          "id": "force_fullscreen",
          "text": "Force fullscreen",
          "image": "system.png",
          "action": "force_fullscreen",
          "order": 30,
          "action_spec": {
            "kind": "custom",
            "name": "force_fullscreen"
          }
        },
        {
          "id": "quit",
          "text": "Sluit deze app",
          "image": "exit.png",
          "action": "exit",
          "order": 40,
          "action_spec": {
            "kind": "app_exit"
          }
        },
        {
          "id": "shell_reboot",
          "text": "Reboot machine",
          "image": "shell.png",
          "action": "shell_reboot",
          "dev_only": true,
          "order": 50,
          "action_spec": {
            "kind": "shell",
            "op": "reboot"
          }
        },
        {
          "id": "shell_shutdown",
          "text": "Shutdown machine",
          "image": "shell.png",
          "action": "shell_shutdown",
          "dev_only": true,
          "order": 60,
          "action_spec": {
            "kind": "shell",
            "op": "shutdown"
          }
        }
      ]
    },
    {
      "id": "screen_off",
      "text": "Zet scherm uit",
      "image": "screen-off.png",
      "action": "turn_screen_off",
      "order": 200,
      "action_spec": {
        "kind": "custom",
        "name": "turn_screen_off"
      }
    },
    {
      "id": "sleep_mode",
      "text": "[sleep_mode_action] Sleep mode",
      "image": "in-bed.png",
      "action": "sleep_mode_toggle",
      "order": 300,
      "action_spec": {
        "kind": "mqtt_action",
        "topic_key": "actions_outgoing",
        "action": "sleep_mode_toggle"
      },
      "state_spec": {
        "type": "device_bool",
        "source": "sleep_mode",
        "default": false,
        "action_text": "[sleep_mode_action]",
        "on_text": "Aan",
        "off_text": "Uit"
      }
    }
  ]
}
