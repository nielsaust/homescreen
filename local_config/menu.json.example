{
  "menu_schema": [
    {
      "id": "system_options",
      "text": "Opties",
      "image": "system.png",
      "action": "open_page",
      "order": 100,
      "screen": [
        {
          "id": "options_back",
          "text": "Terug",
          "image": "back.png",
          "action": "back",
          "order": 10,
          "action_spec": {
            "kind": "menu_nav",
            "command": "back"
          }
        },
        {
          "id": "show_menu_page_number",
          "text": "Toon pagina nummer",
          "image": "tools.png",
          "action": "show_menu_page_number",
          "action_spec": {
            "kind": "setting_toggle",
            "attr": "show_menu_page_number"
          },
          "state_spec": {
            "type": "setting_bool",
            "source": "show_menu_page_number",
            "default": true
          }
        },
        {
          "id": "store_settings",
          "text": "Store settings",
          "image": "system.png",
          "action": "store_settings",
          "order": 20,
          "setting_requirements": [],
          "action_spec": {
            "kind": "setting_toggle",
            "attr": "store_settings"
          },
          "state_spec": {
            "type": "setting_bool",
            "source": "store_settings",
            "default": true
          }
        },
        {
          "id": "force_fullscreen",
          "text": "Force fullscreen",
          "image": "system.png",
          "action": "force_fullscreen",
          "order": 30,
          "action_spec": {
            "kind": "custom",
            "name": "force_fullscreen"
          }
        },
        {
          "id": "check_status",
          "text": "Check status",
          "image": "wifi.png",
          "action": "check_status",
          "order": 35,
          "action_spec": {
            "kind": "custom",
            "name": "show_status_check"
          }
        },
        {
          "id": "simulate_outage_internet",
          "text": "Sim internet outage [sim_inet]",
          "image": "wifi.png",
          "action": "simulate_outage_internet",
          "dev_only": true,
          "order": 36,
          "action_spec": {
            "kind": "setting_toggle",
            "attr": "simulate_outage_internet"
          },
          "state_spec": {
            "type": "setting_bool",
            "source": "simulate_outage_internet",
            "default": false,
            "action_text": "[sim_inet]",
            "on_text": "ON",
            "off_text": "OFF"
          }
        },
        {
          "id": "simulate_outage_weather_service",
          "text": "Sim weather outage [sim_wx]",
          "image": "weather.png",
          "action": "simulate_outage_weather_service",
          "dev_only": true,
          "order": 37,
          "action_spec": {
            "kind": "setting_toggle",
            "attr": "simulate_outage_weather_service"
          },
          "state_spec": {
            "type": "setting_bool",
            "source": "simulate_outage_weather_service",
            "default": false,
            "action_text": "[sim_wx]",
            "on_text": "ON",
            "off_text": "OFF"
          }
        },
        {
          "id": "simulate_outage_mqtt",
          "text": "Sim MQTT outage [sim_mqtt]",
          "image": "mqtt.png",
          "action": "simulate_outage_mqtt",
          "dev_only": true,
          "order": 38,
          "action_spec": {
            "kind": "setting_toggle",
            "attr": "simulate_outage_mqtt"
          },
          "state_spec": {
            "type": "setting_bool",
            "source": "simulate_outage_mqtt",
            "default": false,
            "action_text": "[sim_mqtt]",
            "on_text": "ON",
            "off_text": "OFF"
          }
        },
        {
          "id": "enable_network_simulation",
          "text": "Enable outage simulation [sim]",
          "image": "wifi.png",
          "action": "enable_network_simulation",
          "dev_only": true,
          "order": 39,
          "action_spec": {
            "kind": "setting_toggle",
            "attr": "enable_network_simulation"
          },
          "state_spec": {
            "type": "setting_bool",
            "source": "enable_network_simulation",
            "default": false,
            "action_text": "[sim]",
            "on_text": "ON",
            "off_text": "OFF"
          }
        },
        {
          "id": "quit",
          "text": "Sluit deze app",
          "image": "exit.png",
          "action": "exit",
          "order": 40,
          "action_spec": {
            "kind": "app_exit"
          }
        },
        {
          "id": "shell_reboot",
          "text": "Reboot machine",
          "image": "shell.png",
          "action": "shell_reboot",
          "dev_only": true,
          "order": 50,
          "action_spec": {
            "kind": "shell",
            "op": "reboot"
          }
        },
        {
          "id": "shell_shutdown",
          "text": "Shutdown machine",
          "image": "shell.png",
          "action": "shell_shutdown",
          "dev_only": true,
          "order": 60,
          "action_spec": {
            "kind": "shell",
            "op": "shutdown"
          }
        },
        {
          "id": "idle_screen_options",
          "text": "Idle screen",
          "image": "weather.png",
          "action": "open_page",
          "order": 20,
          "screen": [
            {
              "id": "idle_screen_options_back",
              "text": "Terug",
              "image": "back.png",
              "action": "back",
              "order": 10,
              "action_spec": {
                "kind": "menu_nav",
                "command": "back"
              }
            },
            {
              "id": "show_on_idle_cycle",
              "text": "Show idle [idle_mode]",
              "image": "weather.png",
              "action": "show_on_idle_cycle",
              "order": 20,
              "action_spec": {
                "kind": "setting_cycle",
                "attr": "show_on_idle",
                "values": [
                  "time",
                  "weather",
                  "off"
                ]
              },
              "state_spec": {
                "type": "setting_choice",
                "source": "show_on_idle",
                "default": "time",
                "action_text": "[idle_mode]",
                "choices": {
                  "time": "Tijd",
                  "weather": "Weer",
                  "off": "Uit"
                },
                "inactive_values": [
                  "off"
                ]
              }
            },
            {
              "id": "time_format_cycle",
              "text": "Tijd notatie [time_mode]",
              "image": "clock.png",
              "action": "time_format_cycle",
              "order": 30,
              "action_spec": {
                "kind": "setting_cycle",
                "attr": "time_format",
                "values": [
                  "24h",
                  "12h"
                ]
              },
              "state_spec": {
                "type": "setting_choice",
                "source": "time_format",
                "default": "24h",
                "action_text": "[time_mode]",
                "choices": {
                  "24h": "24u",
                  "12h": "12u"
                }
              }
            },
            {
              "id": "weather_units_cycle",
              "text": "Weer eenheden [weather_units_mode]",
              "image": "weather.png",
              "action": "weather_units_cycle",
              "order": 40,
              "action_spec": {
                "kind": "setting_cycle",
                "attr": "weather_units",
                "values": [
                  "metric",
                  "imperial"
                ]
              },
              "state_spec": {
                "type": "setting_choice",
                "source": "weather_units",
                "default": "metric",
                "action_text": "[weather_units_mode]",
                "choices": {
                  "metric": "Celsius",
                  "imperial": "Fahrenheit"
                }
              }
            }
          ]
        }
      ]
    },
    {
      "id": "screen_off",
      "text": "Zet scherm uit",
      "image": "screen-off.png",
      "action": "turn_screen_off",
      "order": 200,
      "action_spec": {
        "kind": "custom",
        "name": "turn_screen_off"
      }
    },
    {
      "id": "sleep_mode",
      "text": "[sleep_mode_action] Sleep mode",
      "image": "in-bed.png",
      "action": "sleep_mode_toggle",
      "order": 300,
      "action_spec": {
        "kind": "mqtt_action",
        "topic_key": "actions_outgoing",
        "action": "sleep_mode_toggle"
      },
      "state_spec": {
        "type": "device_bool",
        "source": "sleep_mode",
        "default": false,
        "action_text": "[sleep_mode_action]",
        "on_text": "Aan",
        "off_text": "Uit"
      }
    }
  ]
}
