{
  "version": "2026.1.0",
  "log_profile": "default",
  "log_console_level": "INFO",
  "log_file_level": "DEBUG",
  "log_noisy_third_party_debug": false,
  "log_noisy_loggers": ["PIL.PngImagePlugin", "urllib3.connectionpool"],
  "log_domain_levels": {
    "__main__": "INFO",
    "app.controllers.mqtt_controller": "WARNING",
    "app.ui.screens.menu_screen": "INFO",
    "app.ui.screens.music_screen": "INFO",
    "app.ui.ui_render_service": "INFO"
  },
  "do_sentry_logging": false,
  "sentry_dsn": "",
  "sentry_environment": "development",
  "sentry_breadcrumb_level": "INFO",
  "sentry_event_level": "ERROR",
  "sentry_traces_sample_rate": 0.0,
  "sentry_send_default_pii": false,
  "sentry_ignore_loggers": ["PIL.PngImagePlugin", "urllib3.connectionpool"],
  "startup_block_on_internet": false,
  "startup_wait_for_internet_seconds": 10,
  "startup_wait_check_interval_seconds": 5,
  "mqtt_reconnect_interval_seconds": 2,
  "mqtt_reconnect_max_interval_seconds": 60,
  "enable_mqtt": false,
  "enable_music": false,
  "enable_weather": false,
  "app_environment": "production",
  "enable_network_simulation": true,
  "network_status_poll_interval_seconds": 5,
  "show_weather_on_idle": true,
  "screen_width": 720,
  "screen_height": 720,
  "restart_program_style": "application",
  "min_time_between_actions": 0.0,
  "in_bed_turn_off_timeout": 15000,
  "verify_ssl_on_trusted_sources": true,
  "store_settings": true,
  "show_feedback_label_timeout": 2000,
  "menu_edit_hold_ms": 1200,
  "feedback_label_width": 100,
  "feedback_label_height": 100,
  "feedback_label_border": 5,
  "feedback_label_padx": 10,
  "feedback_label_pady": 10,
  "feedback_icon_size": [60, 60],
  "mqtt_broker": "127.0.0.1",
  "mqtt_port": 1883,
  "mqtt_user": "CHANGE_ME",
  "mqtt_password": "CHANGE_ME",
  "mqtt_qos": 2,
  "mqtt_accept_nonessential_messages_after": 10,
  "home_assistant_api_base_url": "https://homeassistant.local",
  "weather_api_key": "CHANGE_ME",
  "weather_city_id": "CHANGE_ME",
  "weather_langage": "nl",
  "weather_update_interval": 300,
  "weather_api_call_direct_retries": 1,
  "weather_api_call_reboot_after_retries": 5,
  "weather_api_failure_action": "none",
  "weather_api_unavailable": false,
  "hold_time": 0.3,
  "gesture_min_movement": 30,
  "force_update": false,
  "media_titles_relative_height": 0.2,
  "media_titles_font_size": 28,
  "media_titles_timeout": 5000,
  "music_update_debounce_ms": 150,
  "music_pause_grace_ms": 1200,
  "music_drop_duplicate_payloads": true,
  "music_apply_transport_immediately": true,
  "music_metrics_log_interval_seconds": 30,
  "music_debug_logging": false,
  "ui_trace_logging": false,
  "ui_trace_followup_ms": 80,
  "media_show_titles": true,
  "media_show_album": true,
  "media_get_remote_image_retry_amount": 3,
  "media_clear_image_before_getting_new": true,
  "media_sanitize_titles": true,
  "close_menu_timeout": 7000,
  "destroy_image_timeout": 10000,
  "menu_button_width": 360,
  "menu_button_height": 300,
  "menu_button_padding": 10,
  "menu_item_font_size": 24,
  "button_down_color_change_time": 1000,
  "menu_border_thickness": 10,
  "button_color": {
    "inactive": "#FFFFFF",
    "active": "#B4E33D",
    "down": "#00A5CF",
    "disabled": "#DCDCDC"
  },
  "menu_background_color": {
    "weather": "#000000",
    "music": "#000000",
    "menu": "#201C29"
  },
  "destroy_slider_timeout": 60000,
  "destroy_cam_timeout": 60000,
  "show_cam_on_print_percentage": 0,
  "printer_screen_blink_on_complete": false,
  "calendar_party_colors": [
    "#ffbe0b",
    "#fb5607",
    "#ff006e",
    "#8338ec",
    "#3a86ff"
  ],
  "calendar_default_color": "#3a86ff",
  "alert_default_show_seconds": 3,
  "alert_default_foreground_color": "#000000",
  "alert_default_background_color": "#ffffff"
}
