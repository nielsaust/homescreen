[Unit]
Description=Homescreen App
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/homescreen
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/pi/homescreen/.venv/bin/python /home/pi/homescreen/main.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
